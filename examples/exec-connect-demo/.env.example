# Server Configuration
PORT=8000

# Logging Configuration (Optional)
# Set to 'debug' to see detailed HTTP requests/responses to Memory/Conversations APIs
# Options: error, warn, info, debug, trace
LOG_LEVEL=debug

# Twilio Configuration (Required)
TWILIO_ACCOUNT_SID=ACxxxx
TWILIO_AUTH_TOKEN=xxxx
TWILIO_PHONE_NUMBER=+1xxx
CONVERSATION_SERVICE_ID=comms_service_xxxx

# Twilio Memory (Optional)
MEMORY_STORE_ID=mem_service_xxxx
MEMORY_API_KEY=xxxx    # This is your Twilio API Key (SKxxxx)
MEMORY_API_TOKEN=xxxx  # This is your Twilio API Secret

# OpenAI Configuration (Required)
OPENAI_API_KEY=sk-xxxx

# Voice Configuration (Optional - must be a full URL with https://)
VOICE_PUBLIC_DOMAIN=https://your-ngrok-domain.ngrok.app

# Conversation Intelligence Configuration (OPTIONAL)
# Required for processing CI webhook events with tac.processCintelEvent()
# Events are filtered by configuration ID.
TWILIO_TAC_CI_CONFIGURATION_ID=your_ci_configuration_id_here
TWILIO_TAC_CI_OBSERVATION_OPERATOR_SID=LYxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TAC_CI_SUMMARY_OPERATOR_SID=LYxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx