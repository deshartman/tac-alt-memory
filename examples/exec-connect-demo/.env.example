# Server Configuration
PORT=8000

# Logging Configuration (Optional)
# Set to 'debug' to see detailed HTTP requests/responses to Memory/Conversations APIs
# Options: error, warn, info, debug, trace
LOG_LEVEL=debug

# Twilio Configuration (Required)
TWILIO_ACCOUNT_SID=ACxxxx
TWILIO_AUTH_TOKEN=xxxx
TWILIO_PHONE_NUMBER=+1xxx
CONVERSATION_SERVICE_ID=comms_service_xxxx

# Twilio API Credentials (Required)
# These credentials are used by Memory, Conversations, and Knowledge APIs
TWILIO_API_KEY=SKxxxx    # Your Twilio API Key (SKxxxx)
TWILIO_API_TOKEN=xxxx    # Your Twilio API Secret

# Twilio Memory (Optional)
MEMORY_STORE_ID=mem_service_xxxx

# Memory Polling (Optional - for real-time Agent Context updates)
MEMORY_POLLING_ENABLED=true       # Set to 'false' to disable polling
MEMORY_POLL_INTERVAL_MS=1500      # Poll interval in milliseconds (default: 1500)

# Profile Service Configuration (REQUIRED - Choose one architecture)
# Architecture 1: 'memora' - Automatic memory pre-fetching (~150ms SMS latency)
# Architecture 2: 'segment' - LLM tool-driven memory (~5ms latency, recommended for new apps)
PROFILE_SERVICE_PROVIDER=memora

# Segment Configuration (Only required if PROFILE_SERVICE_PROVIDER=segment)
# Uncomment these lines when using Segment (Architecture 2)
# SEGMENT_WRITE_KEY=xxxx                    # Segment Source Write Key (from Sources > Settings > API Keys)
# SEGMENT_SPACE_ID=spa_xxxxxxxxxxxx         # Segment Space ID (from Unify > Settings > API access tab, starts with "spa_")
# SEGMENT_ACCESS_TOKEN=sgp_xxxxxxxxx        # Segment Public API Token (from Settings > Workspace Settings > Tokens, optional)
# SEGMENT_UNIFY_TOKEN=xxxxxxxxxxxxxxx       # Segment Unify API Token (from Unify > Settings > API Access, required for Profile API)

# OpenAI Configuration (Required)
OPENAI_API_KEY=sk-xxxx

# Voice Configuration (Optional - must be a full URL with https://)
VOICE_PUBLIC_DOMAIN=https://your-ngrok-domain.ngrok.app

# Conversation Intelligence Configuration (OPTIONAL)
# Required for processing CI webhook events with tac.processCintelEvent()
# Events are filtered by configuration ID.
TWILIO_TAC_CI_CONFIGURATION_ID=your_ci_configuration_id_here
TWILIO_TAC_CI_OBSERVATION_OPERATOR_SID=LYxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TAC_CI_SUMMARY_OPERATOR_SID=LYxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx