# Server Configuration
PORT=8000

# Environment Configuration
ENVIRONMENT=dev

# Twilio Configuration
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# Twilio Agentic Framework Services (Required)
CONVERSATION_SERVICE_ID=comms_service_01kbjqhn79f0fvwfsxqzd5nqhd

# Twilio Memory (Optional - enables memory features, bot works without it)
MEMORY_STORE_ID=mem_service_01kbjqhhdpft0tbp21jt4ktbxg
MEMORY_API_KEY=your_memory_api_key    # This is your Twilio API Key (SKxxxx)
MEMORY_API_TOKEN=your_memory_api_token  # This is your Twilio API Secret

# Optional: Voice Configuration (for multi-channel bots)
VOICE_PUBLIC_DOMAIN=https://your-ngrok-domain.ngrok.io