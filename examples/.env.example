# Environment Configuration
ENVIRONMENT=dev  # Required: 'dev', 'stage', or 'prod'

# Twilio Core Configuration (Required)
TWILIO_ACCOUNT_SID=ACxxxxx...
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890
CONVERSATION_SERVICE_ID=comms_service_01kbjqhn79f0fvwfsxqzd5nqhd

# OpenAI Configuration (Required for AI examples)
OPENAI_API_KEY=sk-xxxxx...

# Twilio Memory Service Configuration (Optional)
MEMORY_STORE_ID=mem_service_01kbjqhhdpft0tbp21jt4ktbxg

# Voice Configuration (Optional - for production voice deployments)
VOICE_PUBLIC_DOMAIN=your-domain.com

# Server Configuration (Optional)
PORT=8000