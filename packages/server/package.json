{
  "name": "@twilio/tac-server",
  "version": "1.0.0",
  "description": "Batteries-included Fastify server for Twilio Agent Connect",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "test": "vitest"
  },
  "keywords": [
    "twilio",
    "ai",
    "agents",
    "server",
    "fastify",
    "framework"
  ],
  "author": "Twilio",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "rimraf": "^5.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "dependencies": {
    "@fastify/formbody": "^8.0.2",
    "@fastify/websocket": "^11.2.0",
    "@twilio/tac-core": "^1.0.0",
    "@twilio/tac-tools": "^1.0.0",
    "fastify": "^5.6.2",
    "fastify-graceful-shutdown": "^5.0.0",
    "ws": "^8.19.0"
  }
}
