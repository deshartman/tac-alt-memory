{
  "name": "twilio-agent-connect",
  "version": "1.0.0",
  "description": "Twilio Agent Connect - A TypeScript framework for building intelligent agents",
  "scripts": {
    "build": "npm run build -w @twilio/tac-core -w @twilio/tac-tools -w @twilio/tac-server -w simple-sms-bot -w multi-channel-demo -w basic-twilio-webhook -w tac-channel-examples -w exec-connect-demo",
    "clean": "npm run clean --workspaces --if-present",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint packages/*/src/**/*.ts examples/*/src/**/*.ts",
    "lint:fix": "eslint packages/*/src/**/*.ts examples/*/src/**/*.ts --fix",
    "format": "prettier --write packages/*/src/**/*.ts examples/*/src/**/*.ts",
    "format:check": "prettier --check packages/*/src/**/*.ts examples/*/src/**/*.ts",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "dev": "npm run dev --workspaces --if-present",
    "example:sms": "npm run dev --workspace=simple-sms-bot",
    "example:multi": "npm run dev --workspace=multi-channel-demo",
    "example:exec": "npm run dev --workspace=exec-connect-demo",
    "postinstall": "node scripts/postinstall.js"
  },
  "keywords": [
    "twilio",
    "ai",
    "agents",
    "framework",
    "typescript"
  ],
  "author": "Twilio",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/twilio/twilio-agent-connect-typescript.git"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "rimraf": "^5.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "main": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js",
      "require": "./index.js"
    }
  },
  "dependencies": {
    "dotenv": "^16.3.0",
    "pino": "^9.0.0",
    "pino-pretty": "^13.0.0",
    "twilio": "^5.10.7",
    "zod": "^3.22.0",
    "@fastify/formbody": "^8.0.2",
    "@fastify/websocket": "^11.2.0",
    "fastify": "^5.6.2",
    "fastify-graceful-shutdown": "^5.0.0",
    "ws": "^8.19.0"
  }
}
