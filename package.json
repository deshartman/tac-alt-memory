{
  "name": "twilio-agent-connect",
  "version": "1.0.0",
  "description": "Twilio Agent Connect - A TypeScript framework for building intelligent agents",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist packages/*/dist",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint packages/*/src/**/*.ts src/**/*.ts",
    "lint:fix": "eslint packages/*/src/**/*.ts src/**/*.ts --fix",
    "format": "prettier --write packages/*/src/**/*.ts src/**/*.ts getting_started/**/*.ts",
    "format:check": "prettier --check packages/*/src/**/*.ts src/**/*.ts getting_started/**/*.ts",
    "typecheck": "tsc --noEmit",
    "example:getting-started": "cd getting_started/examples/openai && npm install && npm run dev"
  },
  "keywords": [
    "twilio",
    "ai",
    "agents",
    "framework",
    "typescript"
  ],
  "author": "Twilio",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/twilio-innovation/twilio-agent-connect-typescript.git"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "rimraf": "^5.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "dependencies": {
    "pino": "^9.0.0",
    "pino-pretty": "^13.0.0",
    "twilio": "^5.10.7",
    "zod": "^3.22.0",
    "@fastify/formbody": "^8.0.2",
    "@fastify/websocket": "^11.2.0",
    "fastify": "^5.6.2",
    "fastify-graceful-shutdown": "^5.0.0",
    "ws": "^8.19.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  }
}
